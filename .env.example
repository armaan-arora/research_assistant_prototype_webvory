# Copy this file to .env and fill in a real key to switch the pipeline into
# LIVE mode (real OpenAI calls). Leave unset to run fully offline for free.

OPENAI_API_KEY= your key
OPENAI_MODEL=gpt-4o-mini

# Optional, if wiring in a real vector DB backend instead of the default
# TF-IDF store in core/vector_store.py
# PINECONE_API_KEY=
# PINECONE_ENV=
